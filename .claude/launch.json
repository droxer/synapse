{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "--directory", "backend", "python", "-m", "api.main"],
      "port": 8000
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev"],
      "port": 3000
    },
    {
      "name": "desktop",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "tauri:dev"],
      "port": 3000
    }
  ]
}
