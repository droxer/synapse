{
  "compilerOptions": {
    "target": "ES2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "typeRoots": ["../web/node_modules/@types"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
