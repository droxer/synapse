# Direct backend URL or frontend proxy URL.
SYNAPSE_TUI_API_URL=http://localhost:8000

# Optional backend API key.
SYNAPSE_TUI_API_KEY=

# Optional proxy secret for trusted direct-backend auth.
SYNAPSE_TUI_PROXY_SECRET=

# Optional direct-backend user identity.
SYNAPSE_TUI_USER_EMAIL=
SYNAPSE_TUI_USER_GOOGLE_ID=
SYNAPSE_TUI_USER_NAME=
SYNAPSE_TUI_USER_PICTURE=

# Optional frontend session cookie for http://localhost:3000/api usage.
SYNAPSE_TUI_COOKIE=

# Optional startup conversation and planner mode.
SYNAPSE_TUI_CONVERSATION_ID=
# SYNAPSE_TUI_PLANNER=true
