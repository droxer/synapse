FROM python:3.12-slim

# Shared system packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    jq \
    procps \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Shared Python packages
RUN pip install --no-cache-dir \
    requests \
    beautifulsoup4 \
    pyyaml \
    openpyxl

RUN mkdir -p /home/user
WORKDIR /home/user
