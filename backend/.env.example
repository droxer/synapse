# Required
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# Sandbox
SANDBOX_PROVIDER=boxlite          # boxlite | e2b
E2B_API_KEY=                      # Required when SANDBOX_PROVIDER=e2b
IMAGE_PROVIDER=minimax            # Image generation provider (minimax)
MINIMAX_API_KEY=                  # Optional, enables image_gen tool
MINIMAX_API_HOST=https://api.minimaxi.com  # or https://api.minimax.io for global

# Optional (defaults shown)
ANTHROPIC_BASE_URL=https://api.anthropic.com
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/hiagent
PLANNING_MODEL=claude-sonnet-4-20250514
TASK_MODEL=claude-sonnet-4-20250514
LITE_MODEL=claude-haiku-4-5-20251001
MAX_ITERATIONS=50
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Storage
STORAGE_PROVIDER=local            # local | r2
STORAGE_DIR=./artifacts           # Local storage directory path
R2_ACCOUNT_ID=                    # Required when STORAGE_PROVIDER=r2
R2_ACCESS_KEY_ID=                 # R2 API token access key
R2_SECRET_ACCESS_KEY=             # R2 API token secret key
R2_BUCKET_NAME=                   # R2 bucket name
R2_PUBLIC_URL=                    # Optional: public bucket URL for direct access

# Auth
AUTH_REQUIRED=false               # When true, all routes require authenticated user
PROXY_SECRET=                     # Shared secret with Next.js proxy; required in production

# Context compaction (long chats, DB replay, Telegram DM continuity — OpenClaw-style rolling summary)
COMPACT_TOKEN_BUDGET=150000       # Estimated tokens before compaction runs
COMPACT_TOKEN_COUNTER=weighted    # weighted | legacy (token estimate for compaction triggers)
COMPACT_FULL_INTERACTIONS=5       # Hot tier: recent tool interactions kept verbatim
COMPACT_FULL_DIALOGUE_TURNS=5     # Hot tier: recent user/assistant pairs in text-only threads
COMPACT_FALLBACK_PREVIEW_CHARS=500
COMPACT_FALLBACK_RESULT_CHARS=1000
COMPACT_SUMMARY_MODEL=            # Empty = use LITE_MODEL for warm-tier / dialogue summaries
COMPACT_DIALOGUE_FALLBACK_CHARS=12000    # If LLM summarisation fails (dialogue mode)
COMPACT_CONTEXT_SUMMARY_MAX_CHARS=32000    # Cap for persisted rolling context_summary (DB)
COMPACT_RECONSTRUCT_TAIL_MESSAGES=80       # When context_summary is set, load last N DB messages only
COMPACT_MEMORY_FLUSH=false        # true = persist heuristic facts from user text before compaction

# Telegram / channels — verified long-term facts injected into prompts
MEMORY_FACT_CONFIDENCE_THRESHOLD=0.85
MEMORY_FACT_TOP_K=8
MEMORY_FACT_PROMPT_TOKEN_CAP=1200

# Channels (Telegram webhooks, etc.)
CHANNELS_ENABLED=false
CHANNELS_WEBHOOK_BASE_URL=        # Public base URL for webhook registration (e.g. ngrok)
